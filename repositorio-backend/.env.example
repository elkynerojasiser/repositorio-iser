NODE_ENV=development
PORT=3000

# API en el host + MySQL en Docker: 127.0.0.1. Con "docker compose up" (API en contenedor), Compose pone DB_HOST=mysql y ignora esto.
# Si root falla desde el host, prueba DB_USER=repositorio_app (tras init del volumen).
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=repositorio_tesis
DB_USER=root
DB_PASSWORD=

JWT_SECRET=cambia_esto_por_un_secreto_largo_y_aleatorio
JWT_EXPIRES_IN=7d

# Solo desarrollo: sincroniza modelos con la BD (no usar en producción)
SYNC_DB=false

# Chat RAG (OpenAI). Sin clave, usa Gemini si está disponible.
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4.1-mini

# Chat RAG (Google Gemini). Prioridad sobre OpenAI si está disponible.
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-flash
