# Copie a .env y rellene con valores reales antes de levantar docker-compose.prod.yml
# Compose lo lee automáticamente para sustituir ${...}.

# Dominio que apunta (registro A) a la IP de la VM. Caddy emite el certificado para este host.
DOMAIN=repositorio.tudominio.edu.co

# Base de datos (MySQL en contenedor)
DB_NAME=repositorio
DB_PASSWORD=cambia_esto_por_un_password_fuerte

# Auth
JWT_SECRET=cambia_esto_por_un_secreto_largo_y_aleatorio
JWT_EXPIRES_IN=7d

# Asistente IA (RAG con OpenAI)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
